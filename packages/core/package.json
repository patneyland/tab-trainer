{
  "name": "@tab-trainer/core",
  "version": "0.1.0",
  "description": "Platform-agnostic music theory + training engine for Tab Trainer.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
